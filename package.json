{
  "name": "domain-driven-architecture-frontend-application-sample",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test:dev": "vitest --ui",
    "test:prod": "vitest --run",
    "coverage": "vitest run --coverage",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare": "husky install",
    "lint": "eslint . --report-unused-disable-directives",
    "commit:changes": "git add -A && cz",
    "pre-commit": "npm run test:prod && npm run lint",
    "install-deps:clean": "pnpm install --frozen-lockfile",
    "install-deps": "pnpm install",
    "start-server": "json-server -p 3500 -w src/entities/counter/infrastructure/data/db.json"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-hooks": "8.0.1",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/styled-components": "5.1.36",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/ui": "4.0.18",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "10.0.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-tsdoc": "0.5.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "json-server": "1.0.0-beta.12",
    "lint-staged": "16.3.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
